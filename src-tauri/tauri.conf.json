{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "彩云笔记",
  "version": "2.0.0-p5.1",
  "identifier": "com.caiyun.notes",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true,
        "dragDropEnabled": false,
        "url": "https://notes.binapp.top"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://notes.binapp.top; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://notes.binapp.top; style-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://notes.binapp.top; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob: https://notes.binapp.top; media-src 'self' blob: data: https://notes.binapp.top; connect-src 'self' https://restapi.amap.com https://notes.binapp.top ws://localhost:*; frame-src 'self' https://notes.binapp.top"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "infoPlist": "./Info.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "devtools": true,
    "updater": {
      "endpoints": [
        "https://notes.binapp.top/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNzI5OEQ3M0M5MjYyQzEKUldUQllwSTgxNWh5d1JKQ3p3dFJOcTNxRmdIZHBNY2F0WDJaVVczRWh5SHR1b0ZVL2Y4eVNkUEcK"
    }
  }
}
